# OpenAI API Key — https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here

# Lemon Squeezy Payment Integration
# Checkout URL'leri: app.lemonsqueezy.com → Products → Share Product → Checkout Link
LS_CHECKOUT_PREMIUM_MONTHLY=https://zemara.lemonsqueezy.com/checkout/buy/422387ea-d06a-4eb0-ab94-c168384d42c8
LS_CHECKOUT_PREMIUM_YEARLY=https://zemara.lemonsqueezy.com/checkout/buy/b17004eb-30ce-4e96-8712-5e54e1f4fd64
LS_CHECKOUT_VIP_MONTHLY=https://zemara.lemonsqueezy.com/checkout/buy/20953a6e-8ac6-4769-930a-c0d07a067555
LS_CHECKOUT_VIP_YEARLY=https://zemara.lemonsqueezy.com/checkout/buy/87568b4f-bad9-4a7d-84f2-5a6ff566daa0

# Webhook imzası: app.lemonsqueezy.com → Settings → Webhooks
LEMONSQUEEZY_WEBHOOK_SECRET=your-webhook-secret-here

# Server
PORT=3000
ALLOWED_ORIGINS=http://localhost:3000

# Admin Token (analytics/push stats endpoint guvenlik)
ADMIN_TOKEN=CHANGE_ME_RANDOM_32_BYTES

# Neon PostgreSQL (önerilen — ücretsiz, supabase gerekmez)
# https://neon.tech → New Project → Connection String (pooled)
DATABASE_URL=postgresql://user:password@ep-xxx.neon.tech/neondb?sslmode=require

# Supabase (alternatif — yoksa JSON dosya fallback kullanılır)
# https://supabase.com → Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGci...service-key...

# Production (Vercel'de env vars olarak ayarla)
# NODE_ENV=production
